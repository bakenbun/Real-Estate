# Server-only values. Copy to .env and replace every placeholder.
# Do not commit .env or place these values in app.js, index.html, or a browser setting.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-supabase-secret-key
WORKSPACE_PASSWORD=choose-a-long-unique-workspace-password

# Optional: the server defaults to http://127.0.0.1:3000.
PORT=3000
HOST=127.0.0.1
